{
  "name": "contract-driven-delivery",
  "version": "1.12.0",
  "description": "Contract-driven delivery kit for AI coding agents: contracts-first, test-first, spec-first. Every change is classified, contracted, TDD-ed, implemented, and gate-verified by an orchestrated agent flow.",
  "keywords": [
    "contract-driven",
    "claude-code",
    "codex",
    "ai-agents",
    "sdd",
    "tdd",
    "specs",
    "contracts",
    "brownfield",
    "multi-agent",
    "cdd-kit"
  ],
  "license": "MIT",
  "author": "Contract-Driven Delivery Contributors",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cdd-kit": "bin/cdd.js"
  },
  "exports": {
    ".": {
      "default": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "assets",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "node build.js && vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
